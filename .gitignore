# ---------------------------------------------------------
# VULNSENTINEL .gitignore
# ---------------------------------------------------------

# 1. Security & Secrets (CRITICAL)
# Never upload API keys, HEC tokens, or webhook URLs to GitHub.
.env
*.pem
*.key

# 2. Local Application State & Databases

vulnsentinel_state.db
mock_itsm_tickets.json
*.log

# 3. Python Artifacts
# Ignore compiled Python files and cache directories.
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 4. OS Generated Files
# Ignore annoying hidden files created by Mac or Windows
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db