# ---------------------------------------------------------
# VULNSENTINEL ENVIRONMENT VARIABLES
# ---------------------------------------------------------

# 1. Splunk HTTP Event Collector (HEC) Settings
# Replace localhost with your Splunk server IP if it is hosted elsewhere.
# Ensure you include the :8088 port and /services/collector path.
SPLUNK_HEC_URL="http://localhost:8088/services/collector"

# Paste the HEC Token you generated inside Splunk under Settings > Data Inputs > HEC
SPLUNK_HEC_TOKEN="your-splunk-hec-token-goes-here"
HF_API_TOKEN="your-hf-api-token-goes-here"
# 2. Enterprise Containment Webhook
# Paste your Discord channel webhook URL here for the automated isolation alerts
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/your-server-id/your-webhook-token"